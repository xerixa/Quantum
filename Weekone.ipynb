    "using QuantumToolbox\n",
    "\n",
    "v1 = basis(2,0)\n",
    "v2 = basis(2,1)\n",
    "\n",
    "sigmax() * v1\n",
    "sigmay() * v2\n",
    "sigmaz() * v1\n",
    "\n"
   ]
