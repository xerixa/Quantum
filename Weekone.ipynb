    "using QuantumToolbox\n",
    "using GLMakie\n",
    "\n",
    "b = Bloch()\n",
    "fig, _ = render(b)\n",
    "point = [ 1/sqrt(3), 1/sqrt(3), 1 / sqrt(3)]\n",
    "add_points!(b,point)\n",
    "\n"
   ]
